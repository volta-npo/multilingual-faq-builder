{
  "name": "@volta-oss/multilingual-faq-builder",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "Build bilingual FAQ pages with owner-approved translations and cultural context notes.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
    "validate": "npm test",
    "certify": "npm run build && node --test test/v3.test.js",
    "test:all": "npm test",
    "clean": "rm -f src/*.js src/*.js.map src/*.d.ts test/*.js test/*.js.map test/*.d.ts",
    "ci": "npm ci && npm test && npm run test:backend --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:build": "docker build -t volta-oss/multilingual-faq-builder:local .",
    "docker:run": "docker compose up --build"
  },
  "keywords": [
    "ai-automation",
    "digital-equity",
    "local-first",
    "oss",
    "v3-production",
    "volta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volta-npo/multilingual-faq-builder.git"
  },
  "homepage": "https://volta-npo.github.io/multilingual-faq-builder/",
  "bugs": {
    "url": "https://github.com/volta-npo/multilingual-faq-builder/issues"
  },
  "author": "Volta OSS Division <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.9.1"
  }
}
